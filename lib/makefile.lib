#!/bin/bash
# ============================================
# Makefile Helper Library
# Provides functions for generating module.mk files
# ============================================

# Prevent direct execution
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "Error: This library cannot be executed directly."
    echo "Usage: source ${BASH_SOURCE[0]}"
    exit 1
fi

# ============================================
# Generate PHONY targets
# Usage: generate_phony "target1 target2 target3"
# ============================================
generate_phony() {
    local targets="$1"
    echo ".PHONY: $targets"
}

# ============================================
# Generate help target for module
# Usage: generate_help_target "module_name" "cmd1|desc1 cmd2|desc2"
# ============================================
generate_help_target() {
    local module_name="$1"
    local commands="$2"
    
    echo "help-$module_name:"
    echo "	@echo \"\""
    echo "	@printf \"\\033[1;33m$module_name module commands:\\033[0m\\n\""
    
    IFS=';' read -ra cmd_array <<< "$commands"
    for cmd in "${cmd_array[@]}"; do
        IFS='|' read -r cmd_name cmd_desc <<< "$cmd"
        echo "	@printf \"  \\033[0;32m%-25s\\033[0m %s\\n\" \"$cmd_name\" \"$cmd_desc\""
    done
    
    echo "	@echo \"\""
}

# ============================================
# Generate module.mk content
# Usage: generate_module_mk "module_name" "cmd1|desc1;cmd2|desc2"
# ============================================
generate_module_mk() {
    local module_name="$1"
    local commands="$2"
    
    # Generate PHONY targets list
    local phony_targets="help-$module_name"
    IFS=';' read -ra cmd_array <<< "$commands"
    for cmd in "${cmd_array[@]}"; do
        IFS='|' read -r cmd_name cmd_desc <<< "$cmd"
        phony_targets="$phony_targets $cmd_name"
    done
    
    cat <<EOF
# ============================================
# $module_name Module
# ============================================

@$module_name := modules/$module_name

$(generate_phony "$phony_targets")

$(generate_help_target "$module_name" "$commands")
EOF
}

export -f generate_phony
export -f generate_help_target
export -f generate_module_mk
