#!/bin/bash
# ============================================
# Colors and Logging Library
# Provides colorized output and logging functions
# ============================================

# Prevent direct execution
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "Error: This library cannot be executed directly."
    echo "Usage: source ${BASH_SOURCE[0]}"
    exit 1
fi

# ============================================
# Color definitions
# ============================================
COLOR_RED=$(printf '\033[0;31m')
COLOR_GREEN=$(printf '\033[0;32m')
COLOR_YELLOW=$(printf '\033[1;33m')
COLOR_BLUE=$(printf '\033[0;34m')
COLOR_PURPLE=$(printf '\033[0;35m')
COLOR_CYAN=$(printf '\033[0;36m')
COLOR_GRAY=$(printf '\033[0;90m')
COLOR_DIM=$(printf '\033[2m')
COLOR_BOLD=$(printf '\033[1m')
COLOR_RESET=$(printf '\033[0m')

# Backward compatibility
RED="$COLOR_RED"
GREEN="$COLOR_GREEN"
YELLOW="$COLOR_YELLOW"
BLUE="$COLOR_BLUE"
GRAY="$COLOR_GRAY"
DIM="$COLOR_DIM"
NC="$COLOR_RESET"

# ============================================
# Logging functions
# ============================================
log_info() {
    echo "${COLOR_BLUE}[INFO]${COLOR_RESET} $1"
}

log_success() {
    echo "${COLOR_GREEN}[SUCCESS]${COLOR_RESET} $1"
}

log_warning() {
    echo "${COLOR_YELLOW}[WARNING]${COLOR_RESET} $1"
}

log_error() {
    echo "${COLOR_RED}[ERROR]${COLOR_RESET} $1"
}

log_debug() {
    if [ "${LOG_DEBUG:-false}" = "true" ]; then
        echo "${COLOR_PURPLE}[DEBUG]${COLOR_RESET} $1"
    fi
}

log_section() {
    echo ""
    echo "${COLOR_BOLD}${COLOR_CYAN}=== $1 ===${COLOR_RESET}"
    echo ""
}

# ============================================
# Export functions
# ============================================
export COLOR_RED
export COLOR_GREEN
export COLOR_YELLOW
export COLOR_BLUE
export COLOR_PURPLE
export COLOR_CYAN
export COLOR_GRAY
export COLOR_DIM
export COLOR_BOLD
export COLOR_RESET
export RED
export GREEN
export YELLOW
export BLUE
export GRAY
export DIM
export NC

export -f log_info
export -f log_success
export -f log_warning
export -f log_error
export -f log_debug
export -f log_section
