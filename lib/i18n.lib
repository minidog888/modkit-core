# Help
help_list() { echo "$(t 'HELP_LIST')"; }
help_info() { echo "$(t 'HELP_INFO')"; }
help_create() { echo "$(t 'HELP_CREATE')"; }
help_enable() { echo "$(t 'HELP_ENABLE')"; }
help_disable() { echo "$(t 'HELP_DISABLE')"; }
help_install() { echo "$(t 'HELP_INSTALL')"; }
help_uninstall() { echo "$(t 'HELP_UNINSTALL')"; }
