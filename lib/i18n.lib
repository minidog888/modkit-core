# Module types
type_core() { echo "$(t 'TYPE_CORE')"; }
type_dependency() { echo "$(t 'TYPE_DEPENDENCY')"; }
type_optional() { echo "$(t 'TYPE_OPTIONAL')"; }

# Export functions for use in other scripts
export -f load_language
export -f get_language_from_config
export -f i18n_init
export -f t
