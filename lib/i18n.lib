#!/bin/bash
# ============================================
# Internationalization library
# Loads language strings based on configuration
# ============================================

# Prevent direct execution
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "Error: This library cannot be executed directly."
    echo "Usage: source ${BASH_SOURCE[0]}"
    exit 1
fi

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CORE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
I18N_DIR="${CORE_DIR}/i18n"

# Default language
DEFAULT_LANG="en"

# Current language (can be overridden)
CURRENT_LANG="${DEFAULT_LANG}"

# Load language strings
load_language() {
    local lang="$1"
    local lang_file="${I18N_DIR}/${lang}"
    
    if [[ -f "$lang_file" ]]; then
        source "$lang_file"
        CURRENT_LANG="$lang"
        return 0
    else
        # Fallback to English
        if [[ "$lang" != "$DEFAULT_LANG" ]]; then
            load_language "$DEFAULT_LANG"
        fi
        return 1
    fi
}

# Get language from config
get_language_from_config() {
    # 首先尝试从 core.ini 中读取 language 配置
    if type source_config >/dev/null 2>&1; then
        local temp_prefix="temp_i18n_"
        source_config "core" "core.ini" "$temp_prefix" 2>/dev/null || true
        local lang_var="${temp_prefix}language"
        if [[ -n "${!lang_var:-}" ]]; then
            echo "${!lang_var}"
            return 0
        fi
    fi
    
    # 尝试从 modules.json 中读取（兼容旧版）
    local config_file="${PROJECT_ROOT:-.}/modules.json"
    if [[ -f "$config_file" ]]; then
        if type parse_json_simple >/dev/null 2>&1; then
            local lang=$(parse_json_simple "$config_file" "config.language")
            if [[ -n "$lang" ]]; then
                echo "$lang"
                return 0
            fi
        fi
    fi
    
    # 尝试从 mod.json 中读取
    local mod_config_file="${PROJECT_ROOT:-.}/mod.json"
    if [[ -f "$mod_config_file" ]]; then
        if type parse_json_simple >/dev/null 2>&1; then
            local lang=$(parse_json_simple "$mod_config_file" "config.language")
            if [[ -n "$lang" ]]; then
                echo "$lang"
                return 0
            fi
        fi
    fi
    
    echo "$DEFAULT_LANG"
    return 1
}

# Initialize i18n
i18n_init() {
    # 使用统一的 get_language_from_config 函数获取语言
    local lang=$(get_language_from_config)
    load_language "$lang"
}

# Get a translated string
t() {
    local key_with_prefix="MSG_$1"
    local key_without_prefix="$1"
    local value=""
    
    # 首先尝试带 MSG_ 前缀的
    if [ -n "${!key_with_prefix+x}" ]; then
        value="${!key_with_prefix}"
    fi
    
    # 如果没有找到，尝试不带前缀的
    if [[ -z "$value" ]] && [ -n "${!key_without_prefix+x}" ]; then
        value="${!key_without_prefix}"
    fi
    
    if [[ -n "$value" ]]; then
        echo "$value"
    else
        # Fallback to key name without prefix
        echo "$1"
    fi
}

# Quick translation functions
# General
msg_initializing() { echo "$(t 'INITIALIZING')"; }
msg_installing() { echo "$(t 'INSTALLING')"; }
msg_uninstalling() { echo "$(t 'UNINSTALLING')"; }
