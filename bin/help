#!/bin/bash
# ============================================
# Help Display Script
# Composer-style design
# ============================================

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
MODULES_DIR="$PROJECT_ROOT/modules"

# Load core libraries - core.lib will set MODKIT_ROOT and LIB_DIR
LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"
source "$LIB_DIR/core.lib"
source "$LIB_DIR/config.lib"
source "$LIB_DIR/colors.lib"
i18n_init

# Load core configuration
source_config "core" "core.ini"

# Get project name from config, default to "Project"
PROJECT_NAME="${core_name:-Project}"

# Read project version from mod.json
PROJECT_VERSION="1.0.0"
if [ -f "$PROJECT_ROOT/mod.json" ]; then
    pv=$(grep '"version"' "$PROJECT_ROOT/mod.json" 2>/dev/null | head -1 | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
    [ -n "$pv" ] && PROJECT_VERSION="$pv"
fi

# Get enabled modules
get_enabled_modules() {
    local modules_config="$PROJECT_ROOT/modules.mk"
    if [ ! -f "$modules_config" ]; then
        echo ""
        return
    fi
    grep "^ENABLE_MODULES := " "$modules_config" 2>/dev/null | cut -d= -f2- | sed -e 's/^ *//' -e 's/ *$//' || echo ""
}

# Print ASCII logo
print_logo() {
    echo ""
    echo "${YELLOW} ___  ___          _ _   ___ _   ${NC}"
    echo "${YELLOW} |  \\/  |         | | | / (_) |  ${NC}"
    echo "${YELLOW} | .  . | ___   __| | |/ / _| |_ ${NC}"
    echo "${YELLOW} | |\\/| |/ _ \\ / _\` |    \\| | __| ${NC}"
    echo "${YELLOW} | |  | | (_) | (_| | |\\  \\ | |_ ${NC}"
    echo "${YELLOW} \\_|  |_/\\___/ \\__,_\\_| \\_/_|\\__| ${NC}"
    echo ""
}

# Print command list from Makefile
print_commands() {
    local makefile_list
    makefile_list=$(cd "$PROJECT_ROOT" && make -qp 2>/dev/null | grep -E '^[a-zA-Z0-9_-]+:' | sed 's/:.*//' | grep -v '^[._]' | grep -v '^help-' | sort -u)
    
    while IFS= read -r target; do
        # Try to get translation via t_cmd helper, fallback to raw description
        desc=$(t_cmd "$target")
        if [[ -z "$desc" ]]; then
            desc=$(grep -m1 "^${target}:.*##" "$PROJECT_ROOT/Makefile" "$PROJECT_ROOT/module.mk" 2>/dev/null | sed 's/.*## *//' | head -1)
        fi
        if [[ -n "$desc" ]]; then
            printf "  ${GREEN}%-20s${NC} %s\n" "$target" "$desc"
        fi
    done <<< "$makefile_list"
}

# Composer-style print helper
print_cmd() {
    local name="$1"
    local desc="$2"
    printf "  ${GREEN}%-16s${NC} %s\n" "$name" "$desc"
}

# Main function
main() {
    print_logo
    echo "${GREEN}${PROJECT_NAME}${NC}  ${YELLOW}ModKit ${PROJECT_VERSION}${NC}"
    echo ""
    
    echo "$(t 'HELP_USAGE')"
    echo "  $(t 'HELP_USAGE_TEXT')"
    echo ""
    echo "$(t 'HELP_AVAILABLE_COMMANDS')"
    echo ""
    
    print_commands
    echo ""
    
    local enabled_modules
    enabled_modules=$(get_enabled_modules)
    
    # Display help for enabled modules
    if [[ -n "$enabled_modules" ]] && [[ "$enabled_modules" != " " ]]; then
        for module in $enabled_modules; do
            if [[ -f "$MODULES_DIR/$module/module.mk" ]]; then
                make -s "help-$module" 2>/dev/null || true
            fi
        done
    fi
    
    echo ""
}

main
